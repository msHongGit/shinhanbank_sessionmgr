# Session Manager - Environment Variables Template

# === Application Settings ===
APP_ENV=dev
DEBUG=true
API_PREFIX=/api/v1

# Sprint 2: API Key 인증 (dev/demo 기본 비활성화)
ENABLE_API_KEY_AUTH=false

# API Keys (호출자별 인증)
# ⚠️ Production 환경에서는 반드시 변경하세요
AGW_API_KEY=agw-api-key
MA_API_KEY=ma-api-key
PORTAL_API_KEY=portal-api-key
VDB_API_KEY=vdb-api-key

# === Redis Configuration ===
# 로컬 개발용 예시 (docker-compose로 띄운 Redis 등)
#REDIS_URL=redis://localhost:6379/0

# Azure Cache for Redis (TLS 포트 10000)
# ACCESS_KEY를 실제 값으로 교체하세요
REDIS_ACCESS_KEY=40eMR6v24M6rghbwNjZeAZJxZIABPERQHAzCaFCHkJY=
REDIS_URL=rediss://default:${REDIS_ACCESS_KEY}@redis-shinhan-sol-test.koreacentral.redis.azure.net:10000/0

# 최대 커넥션 수 (선택사항)
# REDIS_MAX_CONNECTIONS=10

# === Sprint 3+: Database Configuration (향후 사용할 예정) ===
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/session_manager

# Session TTL (초 단위, Redis 사용 시)
# SESSION_CACHE_TTL=3600
# LOCAL_SESSION_TTL=1800
# SESSION_MAP_TTL=3600

# Security (Production 필수)
# SECRET_KEY=your-secret-key-here

# 필수 설정 (환경변수 필수)

# Redis 연결 URL (필수)
REDIS_URL=rediss://default:40eMR6v24M6rghbwNjZeAZJxZIABPERQHAzCaFCHkJY=@redis-shinhan-sol-test.koreacentral.redis.azure.net:10000/0

# JWT 서명 키 (필수)
JWT_SECRET_KEY=39dbebbffbe754a4de8ef25bcc82954b0d41168b1a3cdd2822a26fafb14c0a4c

# 선택적 설정 (기본값 있음, 필요시 오버라이드)

# 디버그 모드 (기본값: true)
DEBUG=true

# API 경로 prefix (기본값: /api/v1)
API_PREFIX=/api/v1

# CORS 허용 Origin (기본값: *)
ALLOWED_ORIGINS=*

# Redis 최대 연결 수 (기본값: 10)
REDIS_MAX_CONNECTIONS=10

# On-Prem Redis Sentinel 설정 (선택적)
# REDIS_SENTINEL_NODES=[["172.23.254.140",5001],["172.23.254.140",5002],["172.23.254.140",5003]]
# REDIS_SENTINEL_MASTER_NAME=mymaster
# REDIS_USERNAME=admin
# REDIS_PASSWORD=<REDIS_PASSWORD>
# REDIS_DB=6

# 세션 TTL (초 단위, 기본값: 300초 = 5분)
SESSION_CACHE_TTL=300

# Global 세션 키 prefix (기본값: gsess)
GLOBAL_SESSION_PREFIX=gsess

# JWT Access Token 만료 시간 (초 단위, 기본값: 300초 = 5분)
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=300

# JWT Refresh Token 만료 시간 (초 단위, 기본값: 330초 = 5분 30초)
JWT_REFRESH_TOKEN_EXPIRE_SECONDS=330

# =========================================================================
# ES 로그 설정 (선택적)
# ES_LOG_PATH: ES 전용 로그(eslog_*.log)를 남길 디렉터리 경로
# 로컬 개발 예시: ES_LOG_PATH=eslogs  (프로젝트 루트 기준 ./eslogs 디렉터리)
# 운영 환경에서는 PVC나 로컬 디스크 마운트 경로 등으로 설정
ES_LOG_PATH=eslogs

# ============================================================================
# MinIO 설정 (선택적)
# MinIO를 통한 배치 프로파일 조회를 사용할 때만 설정

# MinIO 엔드포인트
MINIO_ENDPOINT= http://shinhanbank-minio-722c35.koreacentral.azurecontainer.io:9000

# MinIO Access Key / Secret Key (반드시 환경별 안전한 방법으로 주입)
MINIO_ACCESS_KEY= shinhanbank

MINIO_SECRET_KEY= shinhanbank

# MinIO 버킷 이름 (기본값: shinhanobj)
# MINIO_BUCKET=shinhanobj

# 배치 프로파일 복호화 키 (AES-256, Base64 인코딩된 32바이트 원시 키)
# HSM_ENABLED=true 이면 무시됨
# ENCRYPTION_KEY=${ENCRYPTION_KEY}


#DEFAULT_AZURE_MINIO_ENDPOINT="http://shinhanbank-minio-722c35.koreacentral.azurecontainer.io:9000"
#DEFAULT_AZURE_MINIO_CONSOLE="http://shinhanbank-minio-722c35.koreacentral.azurecontainer.io:9001"

# =========================================================
# LOG ENCRYPTION
# =========================================================
# LOG_ENCRYPT_ENABLED=true  → payload 암호화 (운영)
# LOG_ENCRYPT_ENABLED=false → 평문 로그 (개발/디버그, kubectl logs 에서 확인 가능)
LOG_ENCRYPT_ENABLED=false
LOG_ENCRYPTION_SECRET=${LOG_ENCRYPTION_SECRET}
#LOG_ENCRYPTION_SALT=default-log-encryption-salt

# =========================================================
# HSM (on-prem 운영 시 HSM_ENABLED=true 로 변경)
# =========================================================
HSM_ENABLED=false
#HSM_LIB_PATH=/usr/lib/libCryptoki2_64.so
#HSM_SLOT_ID=0
#HSM_TOKEN_LABEL=${HSM_TOKEN_LABEL}
#HSM_PIN=${HSM_PIN}
#HSM_KEY_LABEL=${HSM_KEY_LABEL}

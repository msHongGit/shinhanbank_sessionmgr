# 로컬에서만 .env 자동 로드 사용, 운영/컨테이너는 false 권장
SHINHAN_SM_LOAD_ENV=true

APP_ENV=dev
DEBUG=true
API_PREFIX=/api/v1
ALLOWED_ORIGINS=*

# Redis (필수) 실제 환경에 맞게 수정해야 합니다.
# REDIS_URL=redis://redis-stack.sas-portal-dev:6379/0
REDIS_URL=rediss://default:40eMR6v24M6rghbwNjZeAZJxZIABPERQHAzCaFCHkJY=@redis-shinhan-sol-test.koreacentral.redis.azure.net:10000/0

REDIS_MAX_CONNECTIONS=10

# 컨테이너에서 실제 Redis를 사용하려면 false로 설정(필수)
USE_MOCK_REDIS=false

# TTL 설정
SESSION_CACHE_TTL=600
SESSION_MAP_TTL=600

# API Keys (호출자별, 현재 필수값 아님)
AGW_API_KEY=dev-agw-api-key
MA_API_KEY=dev-ma-api-key
PORTAL_API_KEY=dev-portal-api-key
VDB_API_KEY=dev-vdb-api-key
CLIENT_API_KEY=dev-client-api-key
EXTERNAL_API_KEY=dev-external-api-key


# Auth 플래그(필수)
# 현재는 false
ENABLE_API_KEY_AUTH=false

# === MariaDB Configuration ===
# MariaDB 연결 정보 (클러스터 내부 DNS 또는 로컬 포트포워드)
# 로컬 테스트: kubectl port-forward svc/my-mariadb 3306:3306 후 localhost 사용
# 클러스터 내부: my-mariadb.mariadb.svc.cluster.local 사용

# 필수: MariaDB 연결 정보
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_USER=root
MARIADB_PASSWORD=ChangeMe!
MARIADB_DATABASE=session_manager

# 선택: 성능 튜닝 (기본값 사용 가능)
MARIADB_POOL_SIZE=10          # 동시 연결 수
MARIADB_MAX_OVERFLOW=20       # 최대 추가 연결 수
MARIADB_POOL_RECYCLE=3600     # 연결 재사용 시간 (1시간)
MARIADB_ECHO=false            # SQL 로깅 비활성화 (운영 환경)
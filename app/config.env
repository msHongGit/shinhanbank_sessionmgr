# Session Manager - Runtime Environment Template (config.env)
#
# 이 파일은 예시/기본 설정용입니다.
# - 로컬 개발: 필요하면 이 파일을 참고해 .env 또는 docker-compose env 로 옮겨 사용
# - 컨테이너/운영: 가능하면 이 파일을 직접 사용하지 말고, 환경변수/Secret 로만 주입
#
# 실제 비밀번호/호스트/키 값은 이 파일에 커밋하지 않는 것을 권장합니다.

############################
# 공통 플래그
############################

# 로컬에서만 .env 자동 로드 사용, 운영/컨테이너는 false 권장
SHINHAN_SM_LOAD_ENV=true

APP_ENV=dev
DEBUG=true
API_PREFIX=/api/v1
ALLOWED_ORIGINS=*


############################
# Redis (필수)
############################

# 실제 환경에 맞게 수정해야 합니다.
# REDIS_URL=redis://redis-stack.sas-portal-dev:6379/0
REDIS_URL=rediss://:$40eMR6v24M6rghbwNjZeAZJxZIABPERQHAzCaFCHkJY=@redis-shinhan-sol-test.koreacentral.redis.azure.net:10000/0

REDIS_MAX_CONNECTIONS=10

# 컨테이너에서 실제 Redis를 사용하려면 false로 설정
USE_MOCK_REDIS=false


############################
# TTL 설정
############################

SESSION_CACHE_TTL=600
SESSION_MAP_TTL=600


############################
# API Keys (호출자별)
# 운영용 실제 값은 Secret/환경변수로만 관리 권장
############################

AGW_API_KEY=dev-agw-api-key
MA_API_KEY=dev-ma-api-key
PORTAL_API_KEY=dev-portal-api-key
VDB_API_KEY=dev-vdb-api-key
CLIENT_API_KEY=dev-client-api-key
EXTERNAL_API_KEY=dev-external-api-key


############################
# Auth 플래그
############################

# 로컬/Dev: false, 운영에서만 true
ENABLE_API_KEY_AUTH=false


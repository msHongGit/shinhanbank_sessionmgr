# 필수 설정 (환경변수 필수)

# Redis 연결 URL (필수)
REDIS_URL=rediss://default:40eMR6v24M6rghbwNjZeAZJxZIABPERQHAzCaFCHkJY=@redis-shinhan-sol-test.koreacentral.redis.azure.net:10000/0

# JWT 서명 키 (필수)
JWT_SECRET_KEY=39dbebbffbe754a4de8ef25bcc82954b0d41168b1a3cdd2822a26fafb14c0a4c

# 선택적 설정 (기본값 있음, 필요시 오버라이드)

# 디버그 모드 (기본값: true)
DEBUG=true

# API 경로 prefix (기본값: /api/v1)
API_PREFIX=/api/v1

# CORS 허용 Origin (기본값: *)
ALLOWED_ORIGINS=*

# Redis 최대 연결 수 (기본값: 10)
REDIS_MAX_CONNECTIONS=10

# 세션 TTL (초 단위, 기본값: 300초 = 5분)
SESSION_CACHE_TTL=300

# Global 세션 키 prefix (기본값: gsess)
GLOBAL_SESSION_PREFIX=gsess

# JWT Access Token 만료 시간 (초 단위, 기본값: 300초 = 5분)
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=300

# JWT Refresh Token 만료 시간 (초 단위, 기본값: 330초 = 5분 30초)
JWT_REFRESH_TOKEN_EXPIRE_SECONDS=330

# ============================================================================
# MariaDB 설정 (선택적, 사용시에만 MariaDB 연결 정보가 없으면 배치 프로파일 조회 기능 비활성화)

# MariaDB 호스트 (기본값: "" - 비어있으면 MariaDB 연결 안 함)
#MARIADB_HOST=my-mariadb.mariadb.svc.cluster.local
MARIADB_HOST=127.0.0.1

# MariaDB 포트 (기본값: 3306)
MARIADB_PORT=3306

# MariaDB 사용자명 (기본값: "")
MARIADB_USER=root

# MariaDB 비밀번호 (기본값: "")
MARIADB_PASSWORD=ChangeMe!

# MariaDB 데이터베이스명 (기본값: "")
MARIADB_DATABASE=session_manager

# MariaDB 연결 풀 크기 (기본값: 10)
MARIADB_POOL_SIZE=10

# MariaDB 최대 오버플로우 연결 수 (기본값: 20)
MARIADB_MAX_OVERFLOW=20

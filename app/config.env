# 로컬에서만 .env 자동 로드 사용, 운영/컨테이너는 false 권장
SHINHAN_SM_LOAD_ENV=true

DEBUG=true
API_PREFIX=/api/v1
ALLOWED_ORIGINS=*

# Redis (필수) 실제 환경에 맞게 수정해야 합니다.
# REDIS_URL=rediss://default:@redis-stack.sas-portal-dev:6379/0
REDIS_URL=rediss://default:40eMR6v24M6rghbwNjZeAZJxZIABPERQHAzCaFCHkJY=@redis-shinhan-sol-test.koreacentral.redis.azure.net:10000/0

REDIS_MAX_CONNECTIONS=10

# TTL 설정
SESSION_CACHE_TTL=300

# API Keys (호출자별, 현재 필수값 아님)
AGW_API_KEY=dev-agw-api-key
MA_API_KEY=dev-ma-api-key
PORTAL_API_KEY=dev-portal-api-key
VDB_API_KEY=dev-vdb-api-key
CLIENT_API_KEY=dev-client-api-key
EXTERNAL_API_KEY=dev-external-api-key


# Auth 플래그(필수)
# 현재는 false
ENABLE_API_KEY_AUTH=false